[dashboard]
password = "replace-with-shared-dashboard-password"

# Free public-read mode. Publish the manifest Google Sheet as CSV and paste
# the published CSV URL here. The manifest rows may contain public Drive share
# links or file IDs in baseline_csv_*, findings_xlsx_*, and findings_jsonl_* columns.
[gdrive_public]
manifest_csv_url = "https://docs.google.com/spreadsheets/d/e/replace-me/pub?output=csv"
# Local development alternative:
# manifest_csv_path = ""

# Service-account mode remains supported as a fallback when gdrive_public is
# not configured, or when public manifest loading fails and these secrets exist.
[gdrive]
# Set false for public-manifest-only deployments. Existing service_account_json
# can remain in the file; it will not be used while this is false.
use_service_account = false

# Preferred: separate folders.
findings_folder_id = "replace-with-output-folder-id"
baseline_folder_id = "replace-with-baseline-folder-id"

# Backward-compatible alternative: use one shared folder instead of the two
# folder IDs above.
# folder_id = "replace-with-shared-google-drive-folder-id"

service_account_json = '''
{
  "type": "service_account",
  "project_id": "replace-me",
  "private_key_id": "replace-me",
  "private_key": "-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n",
  "client_email": "replace-me@replace-me.iam.gserviceaccount.com",
  "client_id": "replace-me",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "replace-me"
}
'''
